generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tool {
  id                String       @id @default(uuid())
  name              String
  totalQuantity     Int
  availableQuantity Int
  dailyPrice        Float
  imageUrl          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  rentalItems       RentalItem[]
  toolItems         ToolItem[]
}

model ToolItem {
  id          String   @id @default(uuid())
  toolId      String
  tool        Tool     @relation(fields: [toolId], references: [id])
  itemNumber  String
  status      ItemStatus @default(AVAILABLE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rentalItemDetails RentalItemDetail[]

  @@unique([toolId, itemNumber])
}

enum ItemStatus {
  AVAILABLE
  RENTED
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  mobile    String   @unique
  village   String
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rentals   Rental[]
}

model Rental {
  id            String       @id @default(uuid())
  customer      Customer     @relation(fields: [customerId], references: [id])
  customerId    String
  startDate     DateTime
  expectedDays  Int
  status        RentalStatus @default(ACTIVE)
  advanceAmount Float
  totalAmount   Float?
  returnedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  rentalItems   RentalItem[]
  payments      Payment[]
}

model RentalItem {
  id                 String   @id @default(uuid())
  rentalId           String
  rental             Rental   @relation(fields: [rentalId], references: [id])
  toolId             String
  tool               Tool     @relation(fields: [toolId], references: [id])
  quantity           Int
  dailyPriceSnapshot Float    // Captured at the time of rental
  returnedQuantity   Int      @default(0) // Track partial returns
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  details            RentalItemDetail[]
}

model RentalItemDetail {
  id           String     @id @default(uuid())
  rentalItemId String
  rentalItem   RentalItem @relation(fields: [rentalItemId], references: [id])
  toolItemId   String
  toolItem     ToolItem   @relation(fields: [toolItemId], references: [id])
  status       ItemStatus @default(RENTED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Payment {
  id            String        @id @default(uuid())
  rental        Rental        @relation(fields: [rentalId], references: [id])
  rentalId      String
  amount        Float
  type          PaymentType
  paymentMethod PaymentMethod @default(CASH)
  createdAt     DateTime      @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  description String
  userId      String?
  createdAt   DateTime @default(now())
}

enum RentalStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum PaymentType {
  ADVANCE
  FINAL_SETTLEMENT
  LATE_FEE
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}
